MONGODB_URI=mongodb://localhost:27017/galaxyos
JWT_SECRET=change-me-to-a-real-secret
ADMIN_PASSWORD=admin123
ADMIN_PIN=1234
USER_PASSWORD=user123

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here
CHUB_API_KEY=your-chub-api-key-here

# Chub AI — uses the universal inference endpoint; model name is sent in the request body.
# https://inference.chub.ai/v1/chat/completions
CHUB_MODEL=mythomax

# Plaid API (https://dashboard.plaid.com)
PLAID_CLIENT_ID=your-plaid-client-id-here
PLAID_SECRET=your-plaid-sandbox-secret-here
PLAID_ENV=sandbox

# Fernet encryption key for Plaid access tokens stored at rest.
# Generate with: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('base64url'))"
FERNET_KEY=your-fernet-key-here

# Webhook URL for Plaid to send real-time transaction/item updates.
# Use ngrok or a similar tunnel for local dev: ngrok http 5173
PLAID_WEBHOOK_URL=https://your-ngrok-url/api/plaid/webhook

# Webhook signature verification — set to true in production
PLAID_WEBHOOK_VERIFICATION=false

# How often the background scheduler re-syncs all linked items (hours)
SYNC_INTERVAL_HOURS=4

# How old a snapshot must be before the endpoint triggers a background refresh
BALANCE_STALE_HOURS=4
INVESTMENT_STALE_HOURS=6
LIABILITY_STALE_HOURS=24
RECURRING_STALE_HOURS=24
