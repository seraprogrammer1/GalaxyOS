MONGODB_URI=mongodb://localhost:27017/galaxyos
JWT_SECRET=change-me-to-a-real-secret
ADMIN_PASSWORD=admin123
ADMIN_PIN=1234
USER_PASSWORD=user123

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here
CHUB_API_KEY=your-chub-api-key-here

# Chub AI proxy URL (append /chat/completions to proxy URL)
# Mars (Mixtral): https://mars.chub.ai/mixtral/v1/chat/completions
# Mars (Asha):    https://mars.chub.ai/chub/asha/v1/chat/completions
# Mercury (Mistral):  https://mercury.chub.ai/mistral/v1/chat/completions
# Mercury (MythoMax): https://mercury.chub.ai/mythomax/v1/chat/completions
CHUB_API_URL=https://mercury.chub.ai/mythomax/v1/chat/completions
CHUB_MODEL=mythomax

# Plaid API (https://dashboard.plaid.com)
PLAID_CLIENT_ID=your-plaid-client-id-here
PLAID_SECRET=your-plaid-sandbox-secret-here
PLAID_ENV=sandbox

# Fernet encryption key for Plaid access tokens stored at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLAID_ENCRYPTION_KEY=your-fernet-key-here
